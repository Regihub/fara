---
import Base from '../layouts/Base.astro';
---

<Base title="História farnosti a kostola">
  <section class="px-4 py-8">
    <h1 class="mb-6 text-2xl text-center font-bold text-slate-900">
      História farnosti a kostola
    </h1>

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold">História farnosti</h2>
      <p>
        Diecézny banskobystrický biskup Mons. Rudolf Baláž zriadil dňa
        1. novembra 1990 farnosť Banská Bystrica – Sásová – Rudlová...
      </p>
    </section>

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold">Kostol</h2>
      <p>
        Kostol sv. Antona a Pavla pustovníkov v obci Sásová bol
        pravdepodobne postavený v prvej polovici 14. storočia...
      </p>
    </section>

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold">Patróni farnosti</h2>
      <p>
        Patrónmi sásovského kostola sú svätý Anton a svätý Pavol.
      </p>
    </section>

    <section>
      <h2 class="mb-4 text-xl font-semibold">Fotogaléria a odkazy</h2>
      <ul class="list-disc pl-6 space-y-2">
        <li>
          <a href="#" class="text-green-700 underline">
            Kostolný zvon
          </a>
        </li>
        <li>
          <a href="#" class="text-green-700 underline">
            Krížová cesta
          </a>
        </li>
        <li>
          <a href="#" class="text-green-700 underline">
            Článok na apsida.sk
          </a>
        </li>
      </ul>
    </section>
  </section>
</Base>