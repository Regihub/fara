<script>
  const sections = document.querySelectorAll('details[name="historia"]');

  sections.forEach((detail) => {
    const summary = detail.querySelector('summary');

    summary?.addEventListener('click', () => {

      const wasOpen = detail.open;

      setTimeout(() => {

        // keď sa kapitola ZATVORILA
        if (wasOpen) {
          window.scrollTo({
            top: 0,
            behavior: 'smooth'
          });

          return;
        }

        // keď sa kapitola OTVORILA
        const isDesktop = window.innerWidth >= 1024;

        const offset = isDesktop ? 90 : 20;

        const y =
          detail.getBoundingClientRect().top +
          window.scrollY -
          offset;

        window.scrollTo({
          top: y,
          behavior: 'smooth'
        });

      }, 150);

    });
  });
</script>