---
import Base from "../../layouts/Base.astro";
---

<Base title="Viac">

  <section class="page-section">

    <div class="page-container">

      <!-- Nadpis -->
      <h1 class="page-title mb-4">
        Viac
      </h1>

      <!-- Karty -->
      <div class="space-y-4">

        <!-- História -->
        <a
          href="/viac/historia"
          class="card card-hover block p-5"
        >
          <h2 class="card-title mb-1">
            História farnosti a kostola
          </h2>

          <p class="section-subtitle text-sm">
            Dejiny farnosti, kostola sv. Antona a Pavla pustovníkov
            a patróni našej farnosti.
          </p>
        </a>

        <!-- Archív -->
<a
  href="/viac/archiv"
  class="card card-hover block p-5"
>
  <h2 class="card-title mb-1">
    Archív farských oznamov
  </h2>

  <p class="section-subtitle text-sm">
    Staršie farské oznamy a prehľad predchádzajúcich týždňov.
  </p>
</a>

        <!-- Ulice -->
        <a
          href="/viac/ulice"
          class="card card-hover block p-5"
        >
          <h2 class="card-title mb-1">
            Ulice farnosti
          </h2>

          <p class="section-subtitle text-sm">
            Zoznam ulíc, ktoré patria do Farnosti
            Banská Bystrica – Stará Sásová.
          </p>
        </a>

        <!-- Fotogaléria -->
        <a
          href="/viac/fotogaleria"
          class="card card-hover block p-5"
        >
          <h2 class="card-title mb-1">
            Fotogaléria
          </h2>

          <p class="section-subtitle text-sm">
            Fotografie zo života farnosti uložené na Zonerame.
          </p>
        </a>

      </div>

<div class="card mt-10 p-5 text-center">
  
  <h3 class="text-sm font-semibold text-green-800 mb-2">
    O webstránke
  </h3>

  <p class="text-xs text-slate-600 leading-relaxed">
    Vytvoril a spravuje<br />
    <span class="font-semibold text-slate-700">
      Peter Reguli
    </span>
  </p>

  <p class="mt-3 text-[11px] text-slate-400">
    Farnosť Stará Sásová – Banská Bystrica
  </p>

</div>

    </div>

  </section>

</Base>
