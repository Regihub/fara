---
import InstallButton from "./InstallButton.astro";

const {
  title = "Farnosť Banská Bystrica – Stará Sásová",
  subtitle = "Kostol sv. Antona a Pavla pustovníkov",
  image = "/images/kostol-stara-sasova.jpg"
} = Astro.props;
---

<section class="relative">

  <div class="relative h-64 overflow-hidden sm:h-80 md:h-[28rem]">

    <!-- Obrázok -->
    <img
      src={image}
      alt={subtitle}
      class="h-full w-full object-cover"
    />

    <!-- Overlay -->
    <div class="absolute inset-0 bg-black/45"></div>

    <!-- Obsah -->
    <div class="absolute inset-0 flex items-center justify-center px-6">

      <div class="max-w-3xl text-center text-white">

        <!-- Nadpis -->
        <h1 class="text-3xl font-bold leading-tight sm:text-4xl md:text-5xl">
          {title}
        </h1>

        <!-- Podnadpis -->
        <p class="mt-2 text-base leading-relaxed text-white/90 sm:text-lg">
          {subtitle}
        </p>

        <!-- PayMe -->
        <a
          href="https://payme.sk/?V=1&IBAN=SK6909000000000433235972&CC=EUR&CN=R%C3%ADmsko-kat.cirkev%2Cfarnos%C5%A5+BB-Star%C3%A1+S%C3%A1sov&AM=5.00&MSG=Na+údržbu+kostola"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-4 inline-flex items-center gap-2 rounded-xl bg-[#003087] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[#00256b]"
        >

          <!-- Ikona -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            class="h-5 w-5 fill-current"
            aria-hidden="true"
          >
            <path d="M17 2H7C4.243 2 2 4.243 2 7v10c0 2.757 2.243 5 5 5h10c2.757 0 5-2.243 5-5V7c0-2.757-2.243-5-5-5zm-1.293 7.707-4 4a1 1 0 01-1.414 0l-2-2 1.414-1.414L11 11.586l3.293-3.293 1.414 1.414z"/>
          </svg>

          <span>
            PayMe na údržbu kostola 5 €
          </span>

        </a>

<!-- InstallButton -->
<div class="mt-4 flex justify-center">
  <InstallButton />
</div>

      </div>

    </div>

  </div>

</section>
