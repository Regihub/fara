---
import Base from '../layouts/Base.astro';
import { getLatestWeek } from '../lib/getLatestWeek';
import { formatDate } from '../lib/formatDate';

const week = await getLatestWeek();
const masses = week.masses || [];
---

<Base title="Sväté omše">
  <section class="mx-auto max-w-4xl px-4 py-8">
    <h1 class="mb-6 text-3xl font-bold">Sväté omše</h1>

    <div class="space-y-4">
      {masses.map((mass) => (
        <div class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-slate-200">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h2 class="text-lg font-semibold">{mass.day}</h2>
              <p class="text-sm text-slate-500">{formatDate(mass.date)}</p>
            </div>
            <div class="text-xl font-bold text-blue-600">{mass.time}</div>
          </div>

          {mass.intention && (
            <p class="mt-3 text-slate-700">{mass.intention}</p>
          )}
        </div>
      ))}
    </div>
  </section>
</Base>