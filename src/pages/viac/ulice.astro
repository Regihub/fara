---
// src/pages/viac/ulice.astro
import Base from "../../layouts/Base.astro";

const streets = [
  "Agátová",
  "Beskydská",
  "Dedinská",
  "Dubová",
  "Ďumbierka",
  "Fatranská",
  "Garbanka",
  "Gerlachovská",
  "Haškova",
  "Hlboká",
  "Chabenecká",
  "Inovecká",
  "Kapitána Jaroša",
  "Kráľovohoľská",
  "Marka Čulena",
  "Mateja Bela",
  "Na Dolinky",
  "Na plaváreň",
  "Na Skalici",
  "Na Tále",
  "Na Zábave",
  "Odbojárov",
  "Pod Bánošom",
  "Pod cintorínom",
  "Pod Hôrkou",
  "Pod Skalkou",
  "Rudlovská cesta",
  "Ružová",
  "Sásovská cesta",
  "Stránska",
  "Strmá",
  "Surovská",
  "Veterná"
];

// zoradenie podľa abecedy
const sorted = [...streets].sort((a, b) =>
  a.localeCompare(b, "sk")
);

// rozdelenie na polovice
const middle = Math.ceil(sorted.length / 2);

const leftColumn = sorted.slice(0, middle);
const rightColumn = sorted.slice(middle);
---

<Base title="Ulice farnosti">

  <section class="page-section">

    <div class="page-container">

      <!-- Nadpis -->
      <h1 class="page-title mb-2">
        Ulice farnosti
      </h1>

      <!-- Podnadpis -->
      <p class="section-subtitle text-center mb-4">
        Do Farnosti Banská Bystrica – Stará Sásová
        patria tieto ulice.
      </p>

      <!-- Zoznam -->
      <div class="card overflow-hidden">

        <!-- Header -->
        <div class="border-b border-green-100 bg-green-50 px-5 py-4">
          <h2 class="card-title">
            Zoznam ulíc ({sorted.length})
          </h2>
        </div>

        <!-- Obsah -->
        <div class="p-5">

          <!-- Mobil: 1 stĺpec | Desktop: 2 -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-2 text-sm text-slate-700">

            <!-- Ľavý -->
            <div class="space-y-1">
              {leftColumn.map((street, index) => (
                <div class="leading-relaxed">
                  <span class="font-medium text-green-800">
                    {index + 1}.
                  </span>{" "}
                  {street}
                </div>
              ))}
            </div>

            <!-- Pravý -->
            <div class="space-y-1">
              {rightColumn.map((street, index) => (
                <div class="leading-relaxed">
                  <span class="font-medium text-green-800">
                    {middle + index + 1}.
                  </span>{" "}
                  {street}
                </div>
              ))}
            </div>

          </div>

        </div>
      </div>

      
    </div>

  </section>

</Base>
