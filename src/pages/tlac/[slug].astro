---
import { formatDate } from '../../lib/formatDate';

export async function getStaticPaths() {

  const files = import.meta.glob(
    '../../content/weeks/*.json',
    { eager: true }
  );

  return Object.entries(files).map(([path]) => ({
    params: {
      slug: path
        .split('/')
        .pop()
        .replace('.json', '')
    }
  }));
}

const { slug } = Astro.params;

const files = import.meta.glob(
  '../../content/weeks/*.json',
  { eager: true }
);

const entry = Object.entries(files).find(([path]) =>
  path.endsWith(`/${slug}.json`)
);

if (!entry) {
  throw new Error(`Week not found: ${slug}`);
}

const week = entry[1].default;
---

<html lang="sk">

<head>

<meta charset="utf-8" />

<title>
  Farské oznamy – {week.title}
</title>

<style>

@page {
  size: A4;
  margin: 15mm;
}

body {
  margin: 0;
  padding: 20px;
  font-family:
    system-ui,
    -apple-system,
    BlinkMacSystemFont,
    "Segoe UI",
    sans-serif;

  background: #f3f4f6;
  color: #111827;
}

.print-toolbar {
  text-align: center;
  margin-bottom: 24px;
}

.print-button {
  background: #15803d;
  color: white;
  border: none;
  border-radius: 999px;
  padding: 12px 24px;
  font-size: 15px;
  font-weight: 600;
  cursor: pointer;
}

.print-button:hover {
  background: #166534;
}

.document {

  max-width: 900px;
  margin: auto;

  background: white;

  border-radius: 24px;

  padding: 32px;

  box-shadow:
    0 4px 12px rgba(0,0,0,.08);
}

.header {

  display: flex;
  gap: 20px;

  align-items: center;

  padding-bottom: 16px;

  border-bottom:
    3px solid #15803d;
}

.logo {

  width: 150px;

  height: auto;
}

.header-content {

  flex: 1;
}

.parish {

  color: #166534;

  font-size: 24px;

  font-weight: 700;
}

.subtitle {

  color: #64748b;

  font-size: 16px;

  margin-top: 2px;
}

.week-title {

  margin-top: 14px;

  font-size: 20px;

  font-weight: 700;
}

.period {

  margin-top: 6px;

  color: #475569;
}

.section {

  margin-top: 28px;
}

.section-title {

  color: #166534;

  font-size: 20px;

  font-weight: 700;

  margin-bottom: 12px;
}

.announcements {

  border: 1px solid #bbf7d0;

  background: #f0fdf4;

  border-radius: 16px;

  padding: 16px;

  white-space: pre-line;
}

.mass-table {

  width: 100%;

  border-collapse: collapse;
}

.mass-table thead th {

  background: #166534;

  color: white;

  text-align: left;

  padding: 10px;
}

.mass-table td {

  padding: 10px;

  border-bottom:
    1px solid #e5e7eb;

  vertical-align: top;
}

.mass-day {

  font-weight: 600;
}

.mass-note {

  margin-top: 4px;

  color: #166534;

  font-style: italic;
}

.footer {

  margin-top: 30px;

  text-align: center;

  color: #64748b;

  font-size: 13px;
}

@media print {

  body {
    background: white;
    padding: 0;
  }

  .print-toolbar {
    display: none;
  }

  .document {

    max-width: none;

    box-shadow: none;

    border-radius: 0;

    padding: 0;
  }

  .week-title {
    font-size: 26pt;
  }
}

</style>

</head>

<body>

<div class="print-toolbar">

  <button
    class="print-button"
    onclick="window.print()"
  >
    🖨️ Vytlačiť oznamy
  </button>

</div>

<div class="document">

  <div class="header">

    <img
      src="/images/znamka.png"
      alt="Znak farnosti"
      class="logo"
    />

    <div class="header-content">

      <div class="parish">
        Farnosť Stará Sásová - Banská Bystrica
      </div>

      <!-- <div class="subtitle">
        -
      </div> -->

      <div class="week-title">
        {week.title}
      </div>

      <div class="period">
        {formatDate(week.weekStart)}
        –
        {formatDate(week.weekEnd)}
      </div>

    </div>

  </div>

  {week.general && (

    <section class="section">

      <h2 class="section-title">
        Farské oznamy
      </h2>

      <div class="announcements">
        {week.general}
      </div>

    </section>

  )}

  <section class="section">

    <h2 class="section-title">
      Sväté omše
    </h2>

    <table class="mass-table">

      <thead>
        <tr>
          <th>Deň</th>
          <th>Čas</th>
          <th>Úmysel/Spomienka</th>
        </tr>
      </thead>

      <tbody>

        {week.masses.map((mass) => (

          <tr>

            <td class="mass-day">
              {mass.day}
            </td>

            <td>
              {mass.time}
            </td>

            <td>

              {mass.intention}

              {mass.place && (
                <div>
                  {mass.place}
                </div>
              )}

              {mass.note && (
                <div class="mass-note">
                  {mass.note}
                </div>
              )}

            </td>

          </tr>

        ))}

      </tbody>

    </table>

  </section>

  <div class="footer">
    Farnosť Banská Bystrica – Stará Sásová
  </div>

</div>

</body>

</html>
