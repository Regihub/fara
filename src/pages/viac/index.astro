---
import Base from "../../layouts/Base.astro";
---

<Base title="Viac">

  <section class="page-section">

    <div class="page-container">

      <!-- Nadpis -->
      <h1 class="page-title mb-4">
        Viac
      </h1>

      <!-- Karty -->
      <div class="space-y-4">

        <!-- História -->
        <a
          href="/viac/historia"
          class="card card-hover block p-5"
        >
          <h2 class="card-title mb-1">
            História farnosti a kostola
          </h2>

          <p class="section-subtitle text-sm">
            Dejiny farnosti, kostola sv. Antona a Pavla pustovníkov
            a patróni našej farnosti.
          </p>
        </a>

        <!-- Archív -->
<a
  href="/viac/archiv"
  class="card card-hover block p-5"
>
  <h2 class="card-title mb-1">
    Archív farských oznamov
  </h2>

  <p class="section-subtitle text-sm">
    Staršie farské oznamy a prehľad predchádzajúcich týždňov.
  </p>
</a>

        <!-- Ulice -->
        <a
          href="/viac/ulice"
          class="card card-hover block p-5"
        >
          <h2 class="card-title mb-1">
            Ulice farnosti
          </h2>

          <p class="section-subtitle text-sm">
            Zoznam ulíc, ktoré patria do Farnosti
            Banská Bystrica – Stará Sásová.
          </p>
        </a>

        <!-- Fotogaléria -->
        <a
          href="/viac/fotogaleria"
          class="card card-hover block p-5"
        >
          <h2 class="card-title mb-1">
            Fotogaléria
          </h2>

          <p class="section-subtitle text-sm">
            Fotografie zo života farnosti uložené na Zonerame.
          </p>
        </a>

      </div>

                                         <!-- PODPIS -->

<div class="mt-12 flex justify-center">

  <div
    class="w-full max-w-sm rounded-3xl border border-slate-200/80
           bg-gradient-to-b from-white to-slate-50
           px-6 py-8 text-center shadow-sm"
  >

    <div class="text-3xl">
      ⛪
    </div>

    <div
      class="mt-3 text-[11px] font-semibold uppercase tracking-[0.25em]
             text-slate-500"
    >
      Farnosť Stará Sásová
    </div>

    <div class="mx-auto mt-4 h-px w-16 bg-slate-200"></div>

    <p class="mt-4 text-sm leading-relaxed text-slate-600">
      Navrhnuté s dôrazom na jednoduchosť a prehľadnosť.
    </p>

    <div class="mt-6 text-xs text-slate-500">
      Správa a vývoj
    </div>

    <div class="mt-1 text-sm font-semibold text-slate-700">
      Peter Reguli
    </div>

    <div class="mt-5 text-[11px] tracking-wider text-slate-400">
      OD ROKU 2026
    </div>

  </div>

</div>



<div class="mt-20 text-center text-xs text-slate-400 leading-relaxed">

  <p>
    Farnosť Stará Sásová
  </p>

  <p class="mt-2 text-[11px] text-slate-500">
    oznamy • liturgia • spoločenstvo
  </p>

  <p class="mt-4 text-[11px] text-slate-400">
    vytvoril a spravuje Peter Reguli
  </p>

</div>



<div class="mt-16 text-center space-y-2">

  <div class="flex items-center justify-center gap-2 text-xs text-slate-500">
    <span class="h-px w-8 bg-slate-200"></span>
    ⛪
    <span class="h-px w-8 bg-slate-200"></span>
  </div>

  <div class="text-sm text-slate-600">
    Farnosť Stará Sásová
  </div>

  <div class="text-[11px] text-slate-400">
    spravuje Peter Reguli
  </div>

</div>



<div class="mt-16 flex justify-center">

  <div class="w-full max-w-md">

    <div class="flex items-center gap-3 justify-center text-slate-500 text-xs">

      <span class="h-px flex-1 bg-slate-200"></span>

      <span class="flex items-center gap-2 whitespace-nowrap">
        ⛪
        <span class="text-slate-600 font-medium">
          Farnosť Stará Sásová
        </span>
      </span>

      <span class="h-px flex-1 bg-slate-200"></span>

    </div>

    <div class="mt-3 text-center text-[11px] text-slate-400">
      vytvoril a spravuje Peter Reguli
    </div>

  </div>

</div>



<div class="mt-14 flex justify-center">

    <div class="w-full max-w-md text-center space-y-4 
              bg-gradient-to-b from-white to-slate-50 
              rounded-2xl py-8 px-6">

    <!-- BRAND -->
    <div class="flex flex-col items-center gap-2">

      <div class="text-3xl">⛪</div>

      <div class="text-sm font-semibold text-green-800 tracking-wide">
        Farnosť Stará Sásová
      </div>

      <div class="h-px w-16 bg-slate-200"></div>

    </div>

    <!-- PURPOSE -->
    <p class="text-sm text-slate-600 leading-relaxed">
      Webstránka prináša oznamy, liturgický prehľad a praktické informácie
      pre spoločenstvo farnosti.
    </p>

    <!-- AUTHOR (subtle, not footer-like) -->
    <div class="text-xs text-slate-400">
      vytvoril a spravuje
      <span class="text-slate-600 font-medium">Peter Reguli</span>
    </div>

  </div>

</div>



<div class="mt-12 flex justify-center">

  <div class="w-full max-w-sm rounded-2xl border border-slate-200 bg-white/70 backdrop-blur px-6 py-5 text-center shadow-sm">

    <!-- horný symbol -->
    <div class="text-2xl mb-2">⛪</div>

    <!-- titul -->
    <div class="text-[12px] tracking-widest text-slate-500 uppercase">
      Farnosť Stará Sásová
    </div>

    <!-- hlavný text -->
    <p class="mt-3 text-sm text-slate-700 leading-relaxed">
      Táto stránka poskytuje oznamy, liturgický prehľad a praktické informácie
      pre spoločenstvo farnosti.
    </p>

    <!-- autor -->
    <div class="mt-4 text-xs text-slate-500">
      Správa a vývoj<br />
      <span class="font-semibold text-slate-700">
        Peter Reguli
      </span>
    </div>

    <!-- jemná línia -->
    <div class="mt-4 h-px bg-slate-100"></div>

    <!-- status vibe -->
    <div class="mt-3 text-[11px] text-slate-400">
      digitálna služba pre komunitu
    </div>

  </div>

</div>



<div class="card mt-10 p-6 text-center space-y-4 bg-gradient-to-b from-white to-slate-50">

  <!-- ikonka -->
  <div class="text-3xl">⛪</div>

  <!-- titul -->
  <div class="text-sm font-semibold text-green-800 tracking-wide">
    O tejto stránke
  </div>

  <!-- hlavný text -->
  <p class="text-sm text-slate-700 leading-relaxed">
    Webstránka slúži pre komunitu Farnosti Stará Sásová – Banská Bystrica.<br />
    Prináša oznamy, liturgiu a praktické informácie pre veriacich.
  </p>

  <!-- autor -->
  <div class="pt-2 text-xs text-slate-500">
    Vytvoril a spravuje<br />
    <span class="font-semibold text-slate-700">
      Peter Reguli
    </span>
  </div>

  <!-- malý „status“ štýl -->
  <div class="text-[11px] text-slate-400 pt-2">
    Aktuálne informácie sa môžu priebežne meniť
  </div>

</div>



<div class="card mt-10 p-6 text-center space-y-3">

  <div class="text-2xl">🙏</div>

  <p class="text-sm text-slate-700">
    Táto stránka vznikla pre ľudí Farnosti Stará Sásová,
    aby mali oznamy a informácie vždy poruke.
  </p>

  <div class="text-xs text-slate-500">
    Vytvoril a spravuje: <strong>Peter Reguli</strong>
  </div>

</div>

    </div>

  </section>

</Base>
