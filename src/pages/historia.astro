---
// src/pages/historia.astro
import Base from "../layouts/Base.astro";
import sections from "../data/history.json";
---

<Base title="História farnosti a kostola">
  <section class="px-5 py-8 pb-16">
    <h1 class="mb-6 text-3xl font-bold text-green-800">
      História farnosti a kostola
    </h1>

    <div class="space-y-4">
      {sections.map((section, index) => (
        <details
          name="historia"
          class="group rounded-2xl border border-gray-200 bg-white shadow-sm"
          open={index === 0}
        >
          <summary class="cursor-pointer list-none px-5 py-4 font-semibold text-green-800 flex items-center justify-between">
            <span>{section.title}</span>
            <span class="text-xl transition-transform group-open:rotate-45">
              +
            </span>
          </summary>

          <div class="border-t border-gray-100 px-5 py-4">
            <div
              class="prose prose-sm max-w-none text-gray-700 leading-relaxed"
              set:html={section.content.replace(/\n/g, "<br>")}
            />
          </div>
        </details>
      ))}
    </div>
  </section>
</Base>