---
import Base from "../../layouts/Base.astro";
---

<Base title="Pomazanie chorých">

  <section class="page-section">

    <div class="page-container">

      <!-- Späť -->
      <a
        href="/sviatosti"
        class="inline-block mb-4 font-medium text-green-700"
      >
        ← Späť na sviatosti
      </a>

      <!-- Nadpis -->
      <h1 class="page-title mb-6">
        Pomazanie chorých
      </h1>

      <!-- Obsah -->
      <div class="details-card p-6">

        <div class="space-y-8 page-text">

          <!-- Úvod -->
          <section>

            <p>
              Pomazanie chorých je sviatosť určená na posilnenie
              tých, ktorí sú skúšaní vážnou chorobou, starobou
              alebo sú v ohrození života.
            </p>

          </section>

          <!-- Účinky -->
          <section>

            <h2 class="details-heading mb-3">
              Účinky sviatosti
            </h2>

            <ul class="list-disc pl-6 space-y-2">

              <li>Pokoj, sila a odvaha znášať utrpenie.</li>

              <li>Spojenie s Kristovým utrpením.</li>

              <li>Odpustenie hriechov, ak chorý nemôže pristúpiť k spovedi.</li>

              <li>Posilnenie proti pokušeniam.</li>

              <li>Príprava na večný život.</li>

              <li>Niekedy aj uzdravenie, ak to slúži pre dobro človeka.</li>

            </ul>

          </section>

          <!-- Kto môže prijať -->
          <section>

            <h2 class="details-heading mb-3">
              Kto môže prijať sviatosť?
            </h2>

            <ul class="list-disc pl-6 space-y-2">

              <li>Vážne chorí.</li>

              <li>Ľudia v pokročilom veku.</li>

              <li>Osoby pred náročnou operáciou.</li>

              <li>Tí, ktorých zdravotný stav sa výrazne zhoršil.</li>

            </ul>

          </section>

          <!-- Miesto slávenia -->
          <section>

            <h2 class="details-heading mb-3">
              Kde sa sviatosť udeľuje?
            </h2>

            <p class="mb-3">
              V kostole pri spoločnom slávení, alebo individuálne
              doma, v nemocnici či inom zariadení.
            </p>

          </section>

          <!-- Ako pripraviť domácnosť -->
          <section>

            <h2 class="details-heading mb-3">
              Ako pripraviť domácnosť
            </h2>

            <ul class="list-disc pl-6 space-y-2">

              <li>Stôl s čistým bielym obrusom.</li>

              <li>Kríž.</li>

              <li>Zapálená svieca.</li>

            </ul>

          </section>

          <!-- Dôležité upozornenie -->
          <section class="rounded-xl border border-yellow-300 bg-yellow-50 p-4">

            <p class="text-sm text-gray-700">
              Kňaza volajte k chorému včas. Pomazanie chorých
              nie je určené iba na posledné chvíle života.
            </p>

          </section>

        </div>

      </div>

    </div>

  </section>

</Base>
