---
import Base from "../../layouts/Base.astro";
---

<Base>
  <main class="p-4 pb-16">
    <a
      href="/sviatosti"
      class="inline-block mb-4 text-green-700 font-medium"
    >
      ← Späť na sviatosti
    </a>

    <h1 class="text-3xl font-bold text-green-800 mb-6">
      Sviatosť zmierenia
    </h1>

    <div class="space-y-8 text-gray-800 leading-relaxed">

      <!-- Úvod -->
      <section>
        <p>
          Sviatosť zmierenia, nazývaná aj svätá spoveď,
          je sviatosťou Božieho milosrdenstva, v ktorej
          nám Boh odpúšťa hriechy a obnovuje priateľstvo s ním.
        </p>
      </section>

      <!-- Iné názvy -->
      <section>
        <h2 class="text-xl font-semibold text-green-800 mb-3">
          Iné názvy
        </h2>
        <ul class="list-disc pl-6 space-y-2">
          <li>Sviatosť odpustenia</li>
          <li>Sviatosť pokánia</li>
          <li>Svätá spoveď</li>
        </ul>
      </section>

      <!-- Hlavné časti -->
      <section>
        <h2 class="text-xl font-semibold text-green-800 mb-3">
          Hlavné časti svätej spovede
        </h2>
        <ol class="list-decimal pl-6 space-y-2">
          <li>Spytovanie svedomia</li>
          <li>Ľútosť nad hriechmi</li>
          <li>Predsavzatie viac nehrešiť</li>
          <li>Vyznanie hriechov kňazovi</li>
          <li>Vykonanie pokánia</li>
        </ol>
      </section>

      <!-- Ako často -->
      <section>
        <h2 class="text-xl font-semibold text-green-800 mb-3">
          Ako často pristupovať k sviatosti zmierenia?
        </h2>
        <ul class="list-disc pl-6 space-y-2">
          <li>Aspoň raz do roka.</li>
          <li>Vždy po ťažkom hriechu.</li>
          <li>Odporúča sa pravidelne, napríklad raz za mesiac.</li>
        </ul>
      </section>

      <!-- Účinky -->
      <section>
        <h2 class="text-xl font-semibold text-green-800 mb-3">
          Účinky sviatosti zmierenia
        </h2>
        <ul class="list-disc pl-6 space-y-2">
          <li>Odpustenie hriechov.</li>
          <li>Zmierenie s Bohom.</li>
          <li>Zmierenie s Cirkvou.</li>
          <li>Obnovenie posväcujúcej milosti.</li>
          <li>Pokoj v srdci a duchovná útecha.</li>
          <li>Posilnenie v boji proti hriechu.</li>
        </ul>
      </section>

      <!-- Poznámka -->
      <section class="bg-green-50 border border-green-200 rounded-xl p-4">
        <p class="text-sm text-gray-700">
          Časy spovedania bývajú zverejnené vo farských oznamoch
          a pred veľkými sviatkami.
        </p>
      </section>

    </div>
  </main>
</Base>