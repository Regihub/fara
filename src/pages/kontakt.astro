---
import Base from "../layouts/Base.astro";
import church from "../data/church.json";
import {
  Phone,
  Mail,
  MapPin,
  Church,
  Building2,
  Globe,
  CreditCard,
  User
} from "lucide-astro";

const locations = {
  fara: {
    name: "Farský úrad Stará Sásová",
    address: `${church.address}, ${church["postalCode"]} ${church.city}`,
    google:
      "https://www.google.sk/maps?f=q&source=s_q&hl=sk&geocode&q=Na+T%C3%A1le+3089/10,+97411+Bansk%C3%A1+Bystrica-S%C3%A1sov%C3%A1&sll=48.669026,19.699024&sspn=3.119948,10.733643&ie=UTF8&hq&hnear=Na+T%C3%A1le+3089/10,+97411+Bansk%C3%A1+Bystrica-S%C3%A1sov%C3%A1&z=15",
    mapycz:
      "https://mapy.com/sk/zakladni?planovani-trasy&rc=9s-FZxRTZo&rs=&rs=osm&ri=&ri=1004937800&mrp=%7B%22c%22%3A112%2C%22dt%22%3A%22%22%2C%22d%22%3Atrue%7D&xc=%5B%5D&rut=1&x=19.1552756&y=48.7558878&z=19"
  },

  kostol: {
    name: "Kostol sv. Antona a Pavla pustovníkov",
    address: "Sásovská cesta 60, Banská Bystrica",
    google:
      "https://www.google.sk/maps/place/Kostol+sv.+Antona+a+Pavla,+pustovn%C3%ADkov/@48.7576848,19.1570198,115m/data=!3m1!1e3!4m15!1m8!3m7!1s0x4715166d4d0fe7d7:0x760b9e14b57de288!2sS%C3%A1sovsk%C3%A1+cesta+2964%2F60,+974+11+Bansk%C3%A1+Bystrica!3b1!8m2!3d48.7576933!4d19.1575304!16s%2Fg%2F11c1bpj81b!3m5!1s0x4715176cce572ba3:0x54deead0842083cf!8m2!3d48.757711!4d19.1573711!16s%2Fg%2F11fm79p24d",
    mapycz:
      "https://mapy.com/sk/zakladni?planovani-trasy&rc=9s-aHxR8GQ&rs=&rs=osm&ri=&ri=1067211612&mrp=%7B%22c%22%3A112%2C%22dt%22%3A%22%22%2C%22d%22%3Atrue%7D&xc=%5B%5D&rut=1&x=19.1570673&y=48.7574669&z=19"
  }
};

const streets = [
  "Agátová", "Beskydská", "Dedinská", "Dubová", "Ďumbierka",
  "Fatranská", "Garbanka", "Gerlachovská", "Haškova", "Hlboká",
  "Chabenecká", "Inovecká", "Kapitána Jaroša", "Kráľovohoľská",
  "Marka Čulena", "Mateja Bela", "Na Dolinky", "Na plaváreň",
  "Na Skalici", "Na Tále", "Na Zábave", "Odbojárov",
  "Pod Bánošom", "Pod cintorínom", "Pod Hôrkou", "Pod Skalkou",
  "Rudlovská cesta", "Ružová", "Sásovská cesta", "Stránska",
  "Strmá", "Surovská", "Veterná"
];
---

<Base>
  <section class="p-5 pb-16">
    <h1 class="text-3xl font-bold text-green-800 mb-6">
      Kontakt
    </h1>

    <div class="space-y-6">

      <!-- FARSKÝ ÚRAD -->
      <div class="bg-white border border-gray-200 rounded-2xl shadow-sm overflow-hidden">
        <div class="bg-green-50 px-4 py-3 border-b border-green-100">
          <div class="flex items-center gap-3">
            <Building2 class="w-5 h-5 text-green-700" />
            <h2 class="font-bold text-green-800">
              {locations.fara.name}
            </h2>
          </div>
        </div>

        <div class="p-4 space-y-4">

          <div class="flex items-start gap-3">
            <MapPin class="w-5 h-5 text-gray-400 mt-0.5 shrink-0" />
            <p class="text-sm text-gray-700">
              {locations.fara.address}
            </p>
          </div>

          <a
            href={`tel:${church.phone}`}
            class="flex items-center gap-3 text-blue-600 font-medium"
          >
            <Phone class="w-5 h-5 shrink-0" />
            <span>{church.phone}</span>
          </a>

          <a
            href={`mailto:${church.email}`}
            class="flex items-center gap-3 text-blue-600 font-medium break-all"
          >
            <Mail class="w-5 h-5 shrink-0" />
            <span>{church.email}</span>
          </a>

          <a
            href="https://starasasova.fara.sk"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3 text-blue-600 font-medium break-all"
          >
            <Globe class="w-5 h-5 shrink-0" />
            <span>www.starasasova.fara.sk</span>
          </a>

          <div class="flex items-start gap-3">
            <User class="w-5 h-5 text-gray-400 mt-0.5 shrink-0" />
            <div class="text-sm text-gray-700">
              <div class="font-medium">Správca farnosti</div>
              <div>Egid Matuševský</div>
            </div>
          </div>

          <div class="flex items-start gap-3">
            <CreditCard class="w-5 h-5 text-gray-400 mt-0.5 shrink-0" />
            <div class="text-sm text-gray-700 space-y-1">
              <div><strong>IČO:</strong> 37955314</div>
              <div><strong>DIČ:</strong> 2022565600</div>
              <div class="break-all">
                <strong>IBAN:</strong><br />
                SK69 0900 0000 0004 3323 5972
              </div>
            </div>
          </div>

          <div class="grid grid-cols-2 gap-3 pt-2">
            <a
              href={locations.fara.google}
              target="_blank"
              rel="noopener noreferrer"
              class="bg-green-700 text-white text-center py-3 rounded-xl text-sm font-semibold hover:bg-green-800 transition"
            >
              Google Maps
            </a>

            <a
              href={locations.fara.mapycz}
              target="_blank"
              rel="noopener noreferrer"
              class="bg-orange-500 text-white text-center py-3 rounded-xl text-sm font-semibold hover:bg-orange-600 transition"
            >
              Mapy.cz
            </a>
          </div>
        </div>
      </div>

      <!-- KOSTOL -->
      <div class="bg-white border border-gray-200 rounded-2xl shadow-sm overflow-hidden">
        <div class="bg-green-50 px-4 py-3 border-b border-green-100">
          <div class="flex items-center gap-3">
            <Church class="w-5 h-5 text-green-700" />
            <h2 class="font-bold text-green-800">
              {locations.kostol.name}
            </h2>
          </div>
        </div>

        <div class="p-4">
          <div class="flex items-start gap-3 text-gray-700">
            <MapPin class="w-5 h-5 text-gray-400 mt-0.5 shrink-0" />
            <p class="text-sm">
              {locations.kostol.address}
            </p>
          </div>

          <div class="grid grid-cols-2 gap-3 mt-5">
            <a
              href={locations.kostol.google}
              target="_blank"
              rel="noopener noreferrer"
              class="bg-green-700 text-white text-center py-3 rounded-xl text-sm font-semibold hover:bg-green-800 transition"
            >
              Google Maps
            </a>

            <a
              href={locations.kostol.mapycz}
              target="_blank"
              rel="noopener noreferrer"
              class="bg-orange-500 text-white text-center py-3 rounded-xl text-sm font-semibold hover:bg-orange-600 transition"
            >
              Mapy.cz
            </a>
          </div>
        </div>
      </div>

      <!-- ULICE FARNOSTI -->
      <details class="bg-white border border-gray-200 rounded-2xl shadow-sm">
        <summary class="cursor-pointer px-4 py-4 font-semibold text-green-800">
          Ulice patriace do farnosti ({streets.length})
        </summary>

        <div class="px-4 pb-4 border-t border-gray-100">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-2 mt-4 text-sm text-gray-700">
            {streets.map((street, index) => (
              <div>
                {index + 1}. {street}
              </div>
            ))}
          </div>
        </div>
      </details>

    </div>
  </section>
</Base>