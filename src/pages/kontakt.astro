---
// src/pages/kontakt.astro

import Base from "../layouts/Base.astro";
import church from "../data/church.json";

const locations = {
  fara: {
    name: "Farský úrad Stará Sásová",
    address: `${church.address}, ${church["postalCode"]} ${church.city}`,
    google:
      "https://maps.google.com/?q=Na+Tale+10+Banska+Bystrica",
    mapycz:
      "https://mapy.com/sk/zakladni?x=19.1552756&y=48.7558878&z=19"
  },

  kostol: {
    name: "Kostol sv. Antona a Pavla pustovníkov",
    address: "Sásovská cesta 60, Banská Bystrica",
    google:
      "https://maps.google.com/?q=Kostol+sv.+Antona+a+Pavla+Banska+Bystrica",
    mapycz:
      "https://mapy.com/sk/zakladni?x=19.1570673&y=48.7574669&z=19"
  }
};
---

<Base title="Kontakt">

  <section class="page-section">

    <div class="page-container">

      <!-- Nadpis -->
      <h1 class="page-title mb-4">
        Kontakt
      </h1>

      <div class="space-y-6">

        <!-- FARSKÝ ÚRAD -->
        <section class="card overflow-hidden">

          <!-- Header -->
          <div class="border-b border-green-100 bg-green-50 px-4 py-3">

            <div class="flex items-center gap-3">

              <span class="text-lg">
                🏠
              </span>

              <h2 class="card-title">
                {locations.fara.name}
              </h2>

            </div>

          </div>

          <!-- Content -->
          <div class="space-y-4 p-4">

            <!-- Adresa -->
            <div class="flex items-start gap-3">

              <span>
                📍
              </span>

              <p class="text-sm text-gray-700">
                {locations.fara.address}
              </p>

            </div>

            <!-- Telefón -->
            <a
              href={`tel:${church.phone}`}
              class="flex items-center gap-3 font-medium text-blue-600"
            >

              <span>
                ☎️
              </span>

              <span>
                {church.phone}
              </span>

            </a>

            <!-- Email -->
            <a
              href={`mailto:${church.email}`}
              class="flex items-center gap-3 break-all font-medium text-blue-600"
            >

              <span>
                ✉️
              </span>

              <span>
                {church.email}
              </span>

            </a>

            <!-- Web -->
            <a
              href="https://starasasova.fara.sk"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 break-all font-medium text-blue-600"
            >

              <span>
                🌐
              </span>

              <span>
                www.starasasova.fara.sk
              </span>

            </a>

            <!-- Správca -->
            <div class="flex items-start gap-3">

              <span>
                👤
              </span>

              <div class="space-y-1 text-sm text-gray-700">

                <div class="font-medium">
                  Správca farnosti
                </div>

                <div>
                  Egid Matuševský
                </div>

              </div>

            </div>

            <!-- IČO / DIČ / IBAN -->
            <div class="flex items-start gap-3">

              <span>
                💳
              </span>

              <div class="space-y-1 text-sm text-gray-700">

                <div>
                  <strong>IČO:</strong> 37955314
                </div>

                <div>
                  <strong>DIČ:</strong> 2022565600
                </div>

                <!-- IBAN -->
                <div class="flex items-center gap-2">

                  <div class="break-all">

                    <strong>IBAN:</strong><br />

                    <span id="iban-text">
                      SK69 0900 0000 0004 3323 5972
                    </span>

                  </div>

                  <button
                    type="button"
                    id="copy-iban"
                    class="mt-5 shrink-0 rounded-lg p-2 text-gray-400 transition hover:bg-gray-100 hover:text-green-700"
                    aria-label="Kopírovať IBAN"
                  >

                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      class="h-5 w-5"
                    >

                      <rect
                        x="9"
                        y="9"
                        width="13"
                        height="13"
                        rx="2"
                      />

                      <path
                        d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
                      />

                    </svg>

                  </button>

                </div>

              </div>

            </div>

            <!-- Mapy -->
            <div class="grid grid-cols-2 gap-3 pt-2">

              <a
                href={locations.fara.google}
                target="_blank"
                rel="noopener noreferrer"
                class="button-primary"
              >
                Google Maps
              </a>

              <a
                href={locations.fara.mapycz}
                target="_blank"
                rel="noopener noreferrer"
                class="rounded-xl bg-orange-500 py-3 text-center text-sm font-semibold text-white transition hover:bg-orange-600"
              >
                Mapy.cz
              </a>

            </div>

          </div>

        </section>

        <!-- KOSTOL -->
        <section class="card overflow-hidden">

          <!-- Header -->
          <div class="border-b border-green-100 bg-green-50 px-4 py-3">

            <div class="flex items-center gap-3">

              <span class="text-lg">
                ⛪
              </span>

              <h2 class="card-title">
                {locations.kostol.name}
              </h2>

            </div>

          </div>

          <!-- Content -->
          <div class="space-y-4 p-4">

            <!-- Adresa -->
            <div class="flex items-start gap-3">

              <span>
                📍
              </span>

              <p class="text-sm text-gray-700">
                {locations.kostol.address}
              </p>

            </div>

            <!-- Mapy -->
            <div class="grid grid-cols-2 gap-3 pt-2">

              <a
                href={locations.kostol.google}
                target="_blank"
                rel="noopener noreferrer"
                class="button-primary"
              >
                Google Maps
              </a>

              <a
                href={locations.kostol.mapycz}
                target="_blank"
                rel="noopener noreferrer"
                class="rounded-xl bg-orange-500 py-3 text-center text-sm font-semibold text-white transition hover:bg-orange-600"
              >
                Mapy.cz
              </a>

            </div>

          </div>

        </section>

      </div>

    </div>

  </section>

  <script>

    const copyBtn = document.getElementById('copy-iban');

    const copyIcon = `
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        class="h-5 w-5"
      >
        <rect
          x="9"
          y="9"
          width="13"
          height="13"
          rx="2"
        />
        <path
          d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
        />
      </svg>
    `;

    copyBtn?.addEventListener('click', async () => {

      const iban = 'SK6909000000000433235972';

      try {

        await navigator.clipboard.writeText(iban);

        copyBtn.innerHTML = '✓';

        setTimeout(() => {
          copyBtn.innerHTML = copyIcon;
        }, 1500);

      } catch (err) {

        console.error('Kopírovanie zlyhalo', err);

      }

    });

  </script>

</Base>