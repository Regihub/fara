---
import { getLatestWeek } from '../lib/getLatestWeek';
import { formatDate } from '../lib/formatDate';

const week = Astro.props.week || await getLatestWeek();

const today = new Date().toLocaleDateString('sv-SE');

const {
  title,
  weekStart,
  weekEnd,
  general,
  masses = []
} = week;
---

<!-- menší horný padding, aby pod Hero nevznikala veľká medzera -->
<section class="py-2">
  <!-- Názov týždňa -->
  <h1 class="mb-2 text-xl sm:text-2xl text-center font-bold text-slate-900">
    {title}
  </h1>

  <!-- Platnosť -->
  <p class="mb-6 text-center text-sm text-slate-600">
    <strong>Platnosť:</strong>
    {formatDate(weekStart).slice(0, 6)} – {formatDate(weekEnd)}
  </p>

  <!-- Všeobecné oznamy -->
  {general && general.trim() && (
    <section class="mb-8 rounded-3xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
      <h2 class="mb-4 text-xl font-semibold text-slate-900 text-center">
        Všeobecné oznamy
      </h2>

      <div
        class="leading-relaxed text-slate-800"
        set:html={general.replace(/\n/g, '<br>')}
      />
    </section>
  )}

  <!-- Sväté omše -->
  <section class="overflow-hidden rounded-3xl bg-white shadow-sm ring-1 ring-slate-200">
    <div class="border-b border-slate-200 px-6 py-4 bg-slate-50">
      <h2 class="text-xl font-semibold text-slate-900 text-center">
        Sväté omše
      </h2>
    </div>

    <div class="divide-y divide-slate-100">
      {masses.map((mass) => (
        <div
          class:list={[
            'px-6 py-4 transition-colors',
            mass.date === today &&
              'bg-green-50 border-l-4 border-green-400'
          ]}
        >
          <!-- Mobil: pod sebou | Desktop: vedľa seba -->
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1 sm:gap-4">
            <!-- Deň a čas -->
            <div class="font-semibold text-slate-900">
              {mass.day} • {mass.time}
            </div>

            <!-- Miesto -->
            {mass.place && (
              <div class="text-sm sm:text-base text-slate-600 sm:text-right">
                {mass.place}
              </div>
            )}
          </div>

          <!-- Poznámka -->
{mass.note && (
  <div class="mt-2 text-sm text-green-700 leading-relaxed">
    {mass.note}
  </div>
)}

          <!-- Úmysel -->
          {mass.intention && (
            <div class="mt-1 text-sm text-slate-800 italic leading-relaxed">
              {mass.intention}
            </div>
          )}
        </div>
      ))}
    </div>
  </section>
</section>