---
import Base from "../../layouts/Base.astro";
---

<Base title="Sviatosť krstu">

  <section class="page-section">

    <div class="page-container">

      <!-- Späť -->
      <a
        href="/sviatosti"
        class="inline-block mb-4 font-medium text-green-700"
      >
        ← Späť na sviatosti
      </a>

      <!-- Nadpis -->
      <h1 class="page-title mb-6">
        Sviatosť krstu
      </h1>

      <!-- Obsah -->
      <div class="details-card p-6">

        <div class="space-y-8 page-text">

          <!-- Čo je krst -->
          <section>

            <h2 class="details-heading mb-3">
              Čo je to krst?
            </h2>

            <ul class="list-disc pl-6 space-y-2">

              <li>Je základom a bránou kresťanského života.</li>

              <li>Bez krstu nemožno prijať ostatné sviatosti.</li>

              <li>Je znovuzrodením z vody a Ducha Svätého.</li>

              <li>Krstom sa stávame Božími deťmi.</li>

              <li>Uvádza človeka do života Cirkvi.</li>

            </ul>

          </section>

          <!-- Účinky -->
          <section>

            <h2 class="details-heading mb-3">
              Účinky sviatosti krstu
            </h2>

            <ul class="list-disc pl-6 space-y-2">

              <li>Odpustenie všetkých hriechov.</li>

              <li>Posväcujúca milosť.</li>

              <li>Včlenenie do Cirkvi.</li>

              <li>Nezmazateľný duchovný znak.</li>

            </ul>

          </section>

          <!-- Nahlásenie -->
          <section>

            <h2 class="details-heading mb-3">
              Nahlásenie krstu
            </h2>

            <p>
              Krst je potrebné nahlásiť osobne vo farskom úrade
              aspoň 2 týždne vopred.
            </p>

            <p class="mt-3">
              Pri nahlásení je potrebný rodný list dieťaťa.
            </p>

          </section>

          <!-- Krstní rodičia -->
          <section>

            <h2 class="details-heading mb-3">
              Krstní rodičia
            </h2>

            <p class="mb-3">
              Dieťa má mať aspoň jedného krstného rodiča.
            </p>

            <ul class="list-disc pl-6 space-y-2">

              <li>Katolík.</li>

              <li>Starší ako 16 rokov.</li>

              <li>Pobirmovaný.</li>

              <li>Vedie príkladný kresťanský život.</li>

              <li>Nie je otcom ani matkou dieťaťa.</li>

            </ul>

          </section>

          <!-- Potrebné veci -->
          <section>

            <h2 class="details-heading mb-3">
              Čo si pripraviť
            </h2>

            <ul class="list-disc pl-6 space-y-2">

              <li>Krstnú sviečku.</li>

              <li>Bielu košieľku.</li>

            </ul>

          </section>

          <!-- Predkrstná príprava -->
          <section>

            <h2 class="details-heading mb-3">
              Predkrstná príprava
            </h2>

            <p>
              Rodičia absolvujú predkrstné poučenie.
              Termín sa dohodne pri nahlásení krstu.
            </p>

          </section>

          <!-- Poznámka -->
          <section class="rounded-xl border border-green-200 bg-green-50 p-4">

            <p class="text-sm text-gray-700">
              Podrobné cirkevno-právne ustanovenia a úplné znenie
              kánonov Kódexu kánonického práva sú k dispozícii
              vo farskom úrade.
            </p>

          </section>

        </div>

      </div>

    </div>

  </section>

</Base>
