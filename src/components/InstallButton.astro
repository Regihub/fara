<button
  id="install-btn"
  style="display:none"
  class="inline-flex items-center gap-1 rounded-xl border border-white/30 bg-white/20 px-4 py-1.5 text-sm font-semibold text-white backdrop-blur-sm transition hover:bg-white/30 leading-none"
>
  <span>📱</span>
  <span>Pridať farskú stránku na plochu</span>
</button>

<script>
  let deferredPrompt;

  const btn = document.getElementById('install-btn');

  // Ak je stránka spustená ako nainštalovaná aplikácia,
  // tlačidlo nezobrazuj.
  if (window.matchMedia('(display-mode: standalone)').matches) {
    btn?.remove();
  }

  window.addEventListener('beforeinstallprompt', (e) => {
    e.preventDefault();

    deferredPrompt = e;

    if (btn) {
      btn.style.display = 'block';
    }
  });

  btn?.addEventListener('click', async () => {
    if (!deferredPrompt) return;

    deferredPrompt.prompt();

    await deferredPrompt.userChoice;

    deferredPrompt = null;
  });

  window.addEventListener('appinstalled', () => {
    btn?.remove();
  });
</script>
