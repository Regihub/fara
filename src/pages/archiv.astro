---
import Base from '../layouts/Base.astro';
import AnnouncementCard from '../components/AnnouncementCard.astro';

const files = import.meta.glob('../content/weeks/*.json', {
  eager: true
});

const weeks = Object.values(files)
  .map((file) => file.default)
  .sort((a, b) => {
    if (a.year !== b.year) return b.year - a.year;
    return b.weekNumber - a.weekNumber;
  });
---

<Base title="Archív farských oznamov">

  <section class="page-section">

    <div class="page-container">

      <!-- História -->
      <a
        href="/historia"
        class="card card-hover mb-8 block overflow-hidden"
      >
        <div class="bg-gradient-to-br from-green-50 to-emerald-100 p-6">

          <h1 class="card-title text-2xl mb-2">
            História farnosti a kostola
          </h1>

          <p class="section-subtitle">
            Dejiny farnosti Stará Sásová, gotického kostola
            sv. Antona a Pavla pustovníkov a príbehy patrónov
            našej farnosti.
          </p>

          <p class="mt-4 font-medium text-green-700">
            Zobraziť históriu →
          </p>

        </div>
      </a>

      <!-- Nadpis -->
      <h2 class="page-title mb-6">
        Archív farských oznamov
      </h2>

      <!-- Oznamy -->
      <div class="space-y-4">
        {weeks.map((week) => (
          <a
            href={`/archiv/${week.year}-W${week.weekNumber}`}
            class="block"
          >
            <AnnouncementCard
              title={week.title}
              date={`${week.weekStart} – ${week.weekEnd}`}
            />
          </a>
        ))}
      </div>

    </div>

  </section>

</Base>