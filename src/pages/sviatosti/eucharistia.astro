---
import Base from "../../layouts/Base.astro";
---

<Base title="Eucharistia">

  <section class="page-section">

    <div class="page-container">

      <!-- Späť -->
      <a
        href="/sviatosti"
        class="inline-block mb-4 font-medium text-green-700"
      >
        ← Späť na sviatosti
      </a>

      <!-- Nadpis -->
      <h1 class="page-title mb-6">
        Eucharistia
      </h1>

      <!-- Obsah -->
      <div class="details-card p-6">

        <div class="space-y-8 page-text">

          <!-- Čo je Eucharistia -->
          <section>

            <h2 class="details-heading mb-3">
              Čo je Eucharistia?
            </h2>

            <p>
              Eucharistia je prameň a vrchol života Cirkvi. Je osobným
              stretnutím s Ježišom Kristom, ktorý je skutočne prítomný
              pod spôsobom chleba a vína.
            </p>

          </section>

          <!-- Iné názvy -->
          <section>

            <h2 class="details-heading mb-3">
              Iné názvy
            </h2>

            <ul class="list-disc pl-6 space-y-2">

              <li>Eucharistia</li>

              <li>Sväté prijímanie</li>

              <li>Svätá omša</li>

              <li>Pánova večera</li>

              <li>Najsvätejšia sviatosť oltárna</li>

              <li>Lámanie chleba</li>

              <li>Viatikum</li>

            </ul>

          </section>

          <!-- Účinky -->
          <section>

            <h2 class="details-heading mb-3">
              Účinky prijímania Eucharistie
            </h2>

            <ul class="list-disc pl-6 space-y-2">

              <li>Zjednotenie s Kristom.</li>

              <li>Rozmnoženie posväcujúcej milosti.</li>

              <li>Odpustenie všedných hriechov.</li>

              <li>Ochrana pred smrteľným hriechom.</li>

              <li>Posilnenie jednoty Cirkvi.</li>

              <li>Pokoj medzi ľuďmi.</li>

            </ul>

          </section>

          <!-- Kto môže prijať -->
          <section>

            <h2 class="details-heading mb-3">
              Kto môže prijať sväté prijímanie?
            </h2>

            <p class="mb-3">
              Eucharistiu môže prijať každý pokrstený katolík,
              ktorý:
            </p>

            <ul class="list-disc pl-6 space-y-2">

              <li>je v stave posväcujúcej milosti,</li>

              <li>verí v skutočnú prítomnosť Krista,</li>

              <li>dodržal eucharistický pôst aspoň 1 hodinu.</li>

            </ul>

          </section>

          <!-- Eucharistický pôst -->
          <section>

            <h2 class="details-heading mb-3">
              Eucharistický pôst
            </h2>

            <p>
              Jednu hodinu pred svätým prijímaním sa veriaci zdržiava
              jedla a nápojov (okrem čistej vody a liekov).
            </p>

          </section>

          <!-- Prvé sväté prijímanie -->
          <section>

            <h2 class="details-heading mb-3">
              Prvé sväté prijímanie detí
            </h2>

            <p class="mb-3">
              Deti prvýkrát prijímajú Eucharistiu zvyčajne
              v 3. ročníku základnej školy.
            </p>

            <p class="mb-3">
              Predpokladom je pravidelná účasť na náboženskej výchove
              a svätých omšiach.
            </p>

            <p class="mb-3">
              Prihlásiť dieťa je potrebné osobne vo farskom úrade
              do konca septembra.
            </p>

            <p>
              Príprava prebieha v škole aj vo farnosti
              počas celého školského roka.
            </p>

          </section>

          <!-- Dôležitá poznámka -->
          <section class="rounded-xl border border-green-200 bg-green-50 p-4">

            <p class="text-sm text-gray-700">
              Kristus povedal:
              <em>
                „Kto je moje telo a pije moju krv,
                má večný život.“
              </em>
              (Jn 6,54)
            </p>

          </section>

        </div>

      </div>

    </div>

  </section>

</Base>
