            </a>
          </li>

          <li>
            <a
              href="http://apsida.sk/c/1398/banska-bystrica-sasova"
              class="underline"
              target="_blank"
              rel="noopener noreferrer"
            >
              Článok o kostole na apsida.sk
            </a>
          </li>
        </ul>
      </div>
    </details>
  </section>
</Base>