---
const path = Astro.url.pathname;

function normalize(url) {
  return url.endsWith('/') && url !== '/'
    ? url.slice(0, -1)
    : url;
}

function isActive(url) {
  return normalize(path) === normalize(url);
}
---

<nav class="fixed bottom-4 left-0 right-0 z-50">
  <div
    class="mx-auto w-[calc(100%-1rem)] max-w-md rounded-3xl border border-green-200 bg-white shadow-2xl"
  >
    <div class="grid grid-cols-5">
      <a
        href="/"
        class={`px-1 py-4 text-center text-sm font-medium rounded-l-3xl ${
          isActive('/')
            ? 'bg-green-100 font-bold text-green-700'
            : 'text-gray-700'
        }`}
      >
        Domov
      </a>

      <a
        href="/archiv"
        class={`px-1 py-4 text-center text-sm font-medium ${
          isActive('/archiv')
            ? 'bg-green-100 font-bold text-green-700'
            : 'text-gray-700'
        }`}
      >
        Archív
      </a>

      <a
        href="/sviatosti"
        class={`px-1 py-4 text-center text-sm font-medium ${
          isActive('/sviatosti')
            ? 'bg-green-100 font-bold text-green-700'
            : 'text-gray-700'
        }`}
      >
        Sviatosti
      </a>

      <a
        href="/kontakt"
        class={`px-1 py-4 text-center text-sm font-medium ${
          isActive('/kontakt')
            ? 'bg-green-100 font-bold text-green-700'
            : 'text-gray-700'
        }`}
      >
        Kontakt
      </a>

      <a
        href="/viac"
        class={`px-1 py-4 text-center text-sm font-medium rounded-r-3xl ${
          isActive('/viac')
            ? 'bg-green-100 font-bold text-green-700'
            : 'text-gray-700'
        }`}
      >
        Viac
      </a>
    </div>
  </div>
</nav>