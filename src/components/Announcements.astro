---
import { getLatestWeek } from '../lib/getLatestWeek';
import { formatDate } from '../lib/formatDate';
import defaultMasses from '../data/masses.json';

const week = Astro.props.week || await getLatestWeek();

const {
  title,
  weekStart,
  weekEnd,
  general,
  masses = []
} = week;

// Normalizácia času (9:00 = 09:00)
const normalizeTime = (time) => {
  return time.replace(/^0/, '');
};
---

<section class="py-2">

  <!-- Názov týždňa -->
  <h1 class="mb-2 text-xl sm:text-2xl text-center font-bold text-slate-900">
    {title}
  </h1>

  <!-- Platnosť -->
  <p class="mb-4 text-center text-sm text-slate-600">
    <strong>Platnosť:</strong>
    {formatDate(weekStart).slice(0, 6)} – {formatDate(weekEnd)}
  </p>

  <!-- Všeobecné oznamy -->
  {general && general.trim() && (
    <section class="card mb-5 p-6">
      <h2 class="mb-4 text-xl font-semibold text-green-800 text-center">
        Všeobecné oznamy
      </h2>

      <div
        class="leading-relaxed text-slate-800"
        set:html={general.replace(/\n/g, '<br>')}
      />
    </section>
  )}

  <!-- Sväté omše -->
  <section class="card overflow-hidden">

    <!-- Header -->
    <div class="border-b border-slate-200 px-6 py-4 bg-slate-50">
      <h2 class="text-xl font-semibold text-green-800 text-center">
        Sväté omše
      </h2>
    </div>

    <!-- Zoznam omší -->
    <div class="divide-y divide-slate-100">

      {masses.map((mass) => {

        // Nájde štandardnú omšu podľa dňa
        const matchedMass = defaultMasses.find(
          (m) =>
            m.day.toLowerCase() ===
            mass.day.toLowerCase()
        );

        // Porovná čas
        const isDifferentTime =
          matchedMass &&
          normalizeTime(matchedMass.time) !==
            normalizeTime(mass.time);

        return (
          <div
  data-date={mass.date}
  class="mass-item px-6 py-4 transition-colors"
>
            <!-- Horný riadok -->
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1 sm:gap-4">

              <!-- Deň a čas -->
              <div class="font-semibold text-slate-900">

                {mass.day} •{' '}

                <span
                  class:list={[
                    isDifferentTime
                      ? 'text-red-600'
                      : 'text-slate-900'
                  ]}
                >
                  {mass.time}
                </span>

              </div>

              <!-- Miesto -->
              {mass.place && (
                <div class="text-sm sm:text-base text-slate-600 sm:text-center">
                  {mass.place}
                </div>
              )}

            </div>

            <!-- Spomienka -->
            {mass.note && (
              <div class="mt-2 text-sm text-green-700 leading-relaxed">
                {mass.note}
              </div>
            )}

            <!-- Úmysel -->
            {mass.intention && (
              <div class="mt-2 text-sm italic text-slate-700 leading-relaxed">
                {mass.intention}
              </div>
            )}

          </div>
        );
      })}

    </div>

  </section>

    <div class="mt-6 text-center">
      <a
        href={`/tlac/${week.year}-W${String(week.weekNumber).padStart(2, '0')}`}
        target="_blank"
        rel="noopener"
        class="button-primary inline-block px-6"
      >
        🖨️ Tlačiť oznamy
      </a>
    </div>

<script>

  document.addEventListener('DOMContentLoaded', () => {

    const today = new Date()
      .toLocaleDateString('sv-SE');

    document
      .querySelectorAll('.mass-item')
      .forEach((item) => {

        if (item.dataset.date === today) {
          item.classList.add('mass-today');
        }

      });

  });

</script>
</section>
