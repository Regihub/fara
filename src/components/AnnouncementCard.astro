---
const { title, date } = Astro.props;
---

<article class="mt-3 flex items-center gap-3 rounded-xl border px-4 py-2">

  <!-- Ikonka -->
  <div class="shrink-0 text-xl">
    📄
  </div>

  <!-- Text -->
  <div>
    <h3 class="font-bold">
      {title}
    </h3>

    <p class="text-sm text-gray-500">
      {date}
    </p>
  </div>

</article>
