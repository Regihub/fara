---
import Base from "../../layouts/Base.astro";
---

<Base title="Viac">

  <section class="page-section">

    <div class="page-container">

      <!-- Nadpis -->
      <h1 class="page-title mb-3">
        Viac
      </h1>

      <!-- Podnadpis -->
      <p class="section-subtitle text-center mb-8">
        Doplnkové informácie o našej farnosti.
      </p>

      <!-- Karty -->
      <div class="space-y-4">

        <!-- Ulice -->
        <a
          href="/viac/ulice"
          class="card card-hover block p-5"
        >
          <h2 class="card-title mb-1">
            Ulice farnosti
          </h2>

          <p class="section-subtitle text-sm">
            Zoznam ulíc, ktoré patria do Farnosti
            Banská Bystrica – Stará Sásová.
          </p>
        </a>

        <!-- Fotogaléria -->
        <a
          href="/viac/fotogaleria"
          class="card card-hover block p-5"
        >
          <h2 class="card-title mb-1">
            Fotogaléria
          </h2>

          <p class="section-subtitle text-sm">
            Fotografie zo života farnosti uložené na Zonerame.
          </p>
        </a>

      </div>

    </div>

  </section>

</Base>