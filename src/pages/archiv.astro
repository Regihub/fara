---
import Base from '../layouts/Base.astro';
import AnnouncementCard from '../components/AnnouncementCard.astro';

const files = import.meta.glob('../content/weeks/*.json', {
  eager: true
});

const weeks = Object.values(files)
  .map((file) => file.default)
  .sort((a, b) => {
    if (a.year !== b.year) return b.year - a.year;
    return b.weekNumber - a.weekNumber;
  });
---

<Base title="Archív farských oznamov">
  <section class="px-4 py-8">

    <!-- História farnosti a kostola -->
    <a
      href="/historia"
      class="mb-8 block rounded-3xl bg-gradient-to-br from-green-50 to-emerald-100 p-6 shadow-sm ring-1 ring-green-200"
    >
      <h1 class="text-2xl font-bold text-green-900">
        História farnosti a kostola
      </h1>

      <p class="mt-2 text-sm leading-relaxed text-green-800">
        Dejiny farnosti Stará Sásová, gotického kostola sv. Antona a Pavla
        pustovníkov a príbehy patrónov našej farnosti.
      </p>

      <p class="mt-4 font-medium text-green-700">
        Zobraziť históriu →
      </p>
    </a>

    <!-- Nadpis archívu -->
    <h2 class="mb-6 text-2xl text-center font-bold text-slate-900">
      Archív farských oznamov
    </h2>

    <!-- Zoznam týždňov -->
    {weeks.map((week) => (
      <a
        href={`/archiv/${week.year}-W${week.weekNumber}`}
        class="block"
      >
        <AnnouncementCard
          title={week.title}
          date={`${week.weekStart} – ${week.weekEnd}`}
        />
      </a>
    ))}
  </section>
</Base>