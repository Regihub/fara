---
import { getLatestWeek } from '../lib/getLatestWeek';

const week = await getLatestWeek();
---

<html lang="sk">
<head>
  <meta charset="utf-8" />
  <title>Tlač farských oznamov</title>

  <style>
    body {
      margin: 0;
      font-family: "Times New Roman", serif;
      background: white;
    }

    .page {
      max-width: 210mm;
      margin: 0 auto;
      padding: 12mm;
    }

    .header {
      display: flex;
      align-items: center;
      gap: 20px;
      border-bottom: 2px solid #16a34a;
      padding-bottom: 10px;
    }

    .logo {
      width: 90px;
    }

    .title {
      flex: 1;
      text-align: center;
    }

    .title h1 {
      margin: 0;
      color: #16a34a;
      font-size: 28px;
      text-transform: uppercase;
    }

    .title h2 {
      margin-top: 8px;
      font-size: 18px;
      font-weight: bold;
    }

    .announcements {
      margin-top: 25px;
      font-size: 15pt;
    }

    .announcements p {
      margin-bottom: 12px;
      text-align: center;
    }

    .masses-title {
      margin-top: 30px;
      border-top: 2px solid #16a34a;
      padding-top: 10px;
      text-align: center;
      font-size: 18pt;
      font-weight: bold;
    }

    .mass-row {
      display: flex;
      margin-bottom: 6px;
      font-size: 14pt;
    }

    .day {
      width: 120px;
      font-weight: bold;
    }

    .time {
      width: 70px;
    }

    .intention {
      flex: 1;
    }

    .print-btn {
      position: fixed;
      top: 20px;
      right: 20px;
      padding: 10px 18px;
      cursor: pointer;
    }

    @media print {

      .print-btn {
        display: none;
      }

      .page {
        max-width: none;
        padding: 0;
      }
    }
  </style>
</head>

<body>

<button
  class="print-btn"
  onclick="window.print()"
>
  Tlačiť
</button>

<div class="page">

  <div class="header">

    <img
      src="/apple-touch-icon.png"
      alt=""
      class="logo"
    />

    <div class="title">
      <h1>Farské a liturgické oznamy</h1>
      <h2>{week.title}</h2>
    </div>

  </div>

  <div class="announcements">

    {week.general.split('\n').map((line) => (
      <p>• {line}</p>
    ))}

  </div>

  <div class="masses-title">
    Úmysly svätých omší
  </div>

  <div>

    {week.masses.map((mass) => (
      <div class="mass-row">

        <div class="day">
          {mass.day}
        </div>

        <div class="time">
          {mass.time}
        </div>

        <div class="intention">
          {mass.intention}
        </div>

      </div>
    ))}

  </div>

</div>

</body>
</html>
