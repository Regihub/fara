---
import BottomNav from "../components/BottomNav.astro";
import DesktopNav from "../components/DesktopNav.astro";
import "../styles/global.css";

const { title = "Farnosť Stará Sásová" } = Astro.props;
---

<html lang="sk">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>

  <body class="m-0 bg-gray-100 text-gray-900">
    <!-- Horná navigácia iba pre desktop -->
    <DesktopNav />

    <!-- Hlavný obsah -->
    <div class="flex min-h-screen justify-center">
      <!--
        Mobil: max-w-md (rovnaké ako doteraz)
        Desktop: širší kontajner kvôli desktop menu
      -->
      <div class="w-full max-w-md lg:max-w-7xl bg-white">
        <!--
          Mobile: spodný padding pre BottomNav
          Desktop: bez paddingu
        -->
        <div class="pb-20 md:pb-0">
          <slot />
        </div>
      </div>
    </div>

    <!-- Spodná navigácia iba pre mobil (už rieši BottomNav komponent) -->
    <BottomNav />
  </body>
</html>